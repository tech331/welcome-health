# Airtable
# Create a personal access token at https://airtable.com/create/tokens
# with scopes: data.records:read, data.records:write, schema.bases:read
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=apphNCGqCCoSO0XEJ
AIRTABLE_REQUESTS_TABLE_ID=tblsenO8jvgTFhfHw
AIRTABLE_CLIENTS_TABLE_ID=Clients
AIRTABLE_CASE_MANAGERS_TABLE_ID=tblvcPNOPrf48XuB7
AIRTABLE_PAYERS_TABLE_ID=Payers
AIRTABLE_SUPPLIERS_TABLE_ID=Suppliers
AIRTABLE_ITEMS_TABLE_ID=tblvY7qWlqrtjXvR9
# Requestor options are sourced from the Users table
AIRTABLE_USERS_TABLE_ID=tbl7fqZOh1l9zfGiH
AIRTABLE_QUOTES_TABLE_ID=tblgXBwjlZCl3nGFy
AIRTABLE_ACTIVITIES_TABLE_ID=tblaElDNG68teCUTz

# Google Maps Places API key for address autocomplete (client-side).
# Enable "Places API" + "Maps JavaScript API" and restrict the key to your
# domains. Address search falls back to manual entry when this is unset.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Resend — acknowledgement email on new request submission
RESEND_API_KEY=
ACKNOWLEDGEMENT_FROM_EMAIL=hello@welcomehealth.com.au
ACKNOWLEDGEMENT_TO_EMAIL=camille@nimbushealth.com.au
# Public app URL for links in emails (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=
